    "exposure_course": {
      "type": "boolean"
    },
    "paid_external_placement": {
      "type": "boolean"
    },
    "employment_supports": {
      "type": "boolean"
    },
    "internal_placement": {
      "type": "string",
      "enum": [
        "none",
        "cleaning_arc",
        "food_services_onsite",
        "food_services_offsite",
        "reception",
        "childcare"
      ]
    },
    "internal_placement_details": {
      "type": "string"
    },
    "placement_start_date": {
      "type": "string",
      "format": "date"
    },
    "placement_end_date": {
      "type": "string",
      "format": "date"
    },
    "placement_supervisor": {
      "type": "string"
    },
    "placement_schedule": {
      "type": "string"
    },
    "placement_request_sent": {
      "type": "boolean"
    },
    "external_employer": {
      "type": "boolean"
    },
    "employer_name": {
      "type": "string"
    },
    "employer_contact": {
      "type": "string"
    },
    "job_title": {
      "type": "string"
    },
    "job_start_date": {
      "type": "string",
      "format": "date"
    },
    "job_wage": {
      "type": "number"
    },
    "job_hours": {
      "type": "string"
    },
    "sdp_items": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "sdp_item_details": {
      "type": "object"
    },
    "sdp_other_desc": {
      "type": "string"
    },
    "sdp_notes": {
      "type": "string"
    },
    "internal_referrals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "external_referrals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "career_objectives": {
      "type": "string"
    },
    "employment_history": {
      "type": "string"
    },
    "resume_urls": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "education_history": {
      "type": "string",
      "description": "JSON string of education history entries"
    },
    "self_registered": {
      "type": "boolean",
      "default": false,
      "description": "Whether this client self-registered through the public portal"
    },
    "barrier_description": {
      "type": "string",
      "description": "Self-described circumstances that may affect employment (from public intake)"
    },
    "income_source": {
      "type": "string",
      "enum": [
        "income_support",
        "employment_insurance",
        "aish_adap",
        "employment",
        "other"
      ],
      "description": "Primary source of income"
    },
    "income_source_other": {
      "type": "string",
      "description": "If income source is 'other', specify"
    },
    "legally_entitled_to_work": {
      "type": "string",
      "enum": [
        "yes",
        "no"
      ],
      "description": "Whether the client is legally entitled to work in Canada"
    },
    "drivers_license_status": {
      "type": "string",
      "enum": [
        "yes_no_vehicle",
        "yes_with_vehicle",
        "no"
      ],
      "description": "Driver's license and vehicle access status"
    },
    "has_alternate_id": {
      "type": "string",
      "enum": [
        "yes",
        "no"
      ],
      "description": "Whether the client has an alternate form of ID (if no driver's license)"
    },
    "has_phone_access": {
      "type": "string",
      "enum": [
        "yes",
        "no"
      ],
      "description": "Whether the client has access to a phone"
    },
    "has_internet_access": {
      "type": "string",
      "enum": [
        "yes",
        "no"
      ],
      "description": "Whether the client has access to the internet"
    },
    "available_immediately": {
      "type": "string",
      "enum": [
        "yes",
        "no"
      ],
      "description": "Whether the client is available to start work immediately"
    },
    "current_programming": {
      "type": "string",
      "description": "Other programming the client is currently participating in (employment, ELL, etc.)"
    },
    "previous_employment_program": {
      "type": "string",
      "enum": [
        "yes",
        "no"
      ],
      "description": "Whether the client has previously been in an employment program"
    },
    "has_criminal_record": {
      "type": "string",
      "enum": [
        "yes",
        "no",
        "prefer_not_to_say"
      ],
      "description": "Whether the client has a criminal record"
    },
    "highest_education": {
      "type": "string",
      "enum": [
        "no_formal_education",
        "some_elementary",
        "elementary_completed",
        "some_high_school",
        "high_school_diploma",
        "ged",
        "some_college",
        "college_diploma",
        "college_certificate",
        "bachelors_degree",
        "masters_degree",
        "doctorate",
        "trade_certificate",
        "apprenticeship",
        "professional_certification",
        "other"
      ],
      "description": "Highest level of education completed"
    },
    "has_sin": {
      "type": "string",
      "enum": [
        "yes",
        "no"
      ],
      "description": "Whether the client has a Social Insurance Number"
    },
    "intake_notes": {
      "type": "string"
    },
    "intake_date": {
      "type": "string",
      "format": "date"
    },
    "program_stream_switches": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "from_stream": {
            "type": "string"
          },
          "to_stream": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "reason_other": {
            "type": "string"
          },
          "date": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "roadmap_item_status": {
      "type": "object"
    },
    "roadmap_progress_notes": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "casual_activity_log": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "dea_activities": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "dea_closing_dismissed": {
      "type": "boolean"
    },
    "file_closed": {
      "type": "boolean"
    },
    "closed_reason": {
      "type": "string"
    },
    "closed_date": {
      "type": "string",
      "format": "date"
    },
    "closed_notes": {
      "type": "string"
    }
  },
  "required": [
    "first_name",
    "last_name"
  ]
}