    },
    "barrier_2_timeline_end": {
      "type": "string",
      "format": "date"
    },
    "barrier_2_responsible": {
      "type": "string"
    },
    "barrier_2_resources": {
      "type": "string"
    },
    "barrier_3": {
      "type": "string"
    },
    "barrier_3_status": {
      "type": "string",
      "enum": [
        "unresolved",
        "in_progress",
        "resolved"
      ]
    },
    "barrier_3_notes": {
      "type": "string"
    },
    "barrier_3_action_steps": {
      "type": "string"
    },
    "barrier_3_other": {
      "type": "string"
    },
    "barrier_3_challenges": {
      "type": "string"
    },
    "barrier_3_timeline_start": {
      "type": "string",
      "format": "date"
