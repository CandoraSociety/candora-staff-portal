{
  "name": "TrainingRole",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Role name (e.g. Front Desk Staff, Kitchen Lead, Volunteer)"
    },
    "description": {
      "type": "string"
    },
    "department": {
      "type": "string"
    },
    "sort_order": {
      "type": "number",
      "default": 0
    },
    "is_active": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "name"
  ]
}