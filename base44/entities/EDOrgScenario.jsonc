{
  "name": "EDOrgScenario",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Scenario / sheet name"
    },
    "positions": {
      "type": "array",
      "description": "Snapshot of positions for this scenario",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "original_id": {
            "type": "string",
            "description": "ID from the canonical org if duplicated"
          },
          "title": {
            "type": "string"
          },
          "person_name": {
            "type": "string"
          },
          "department": {
            "type": "string"
          },
          "tier": {
            "type": "string"
          },
          "reports_to_id": {
            "type": "string"
          },
          "salary": {
            "type": "number"
          },
          "is_vacant": {
            "type": "boolean"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "removed_positions": {
      "type": "array",
      "description": "Positions that were deleted from this scenario (for display in the removed list)",
      "items": {
        "type": "object"
      }
    },
    "owner_id": {
      "type": "string"
    }
  },
  "required": [
    "name"
  ]
}