{
  "name": "ProjectGroup",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Group or program area name"
    },
    "description": {
      "type": "string"
    },
    "color": {
      "type": "string",
      "description": "Hex color for visual identification"
    },
    "lead_email": {
      "type": "string"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "name"
  ]
}