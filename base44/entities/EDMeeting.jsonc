{
  "name": "EDMeeting",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Meeting title"
    },
    "meeting_date": {
      "type": "string",
      "format": "date-time",
      "description": "Date and time of meeting"
    },
    "location": {
      "type": "string",
      "description": "Meeting location or video link"
    },
    "meeting_type": {
      "type": "string",
      "enum": [
        "Staff Meeting",
        "Leadership Team",
        "1-on-1",
        "Board Meeting",
        "External/Partner",
        "All-Hands",
        "Committee",
        "Other"
      ],
      "default": "Staff Meeting"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "scheduled",
        "completed",
        "cancelled"
      ],
      "default": "draft"
    },
    "attendees": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of attendee names"
    },
    "facilitator": {
      "type": "string",
      "description": "Person facilitating the meeting"
    },
    "objectives": {
      "type": "string",
      "description": "Meeting objectives \u2014 what should be achieved"
    },
    "notes": {
      "type": "string",
      "description": "General meeting notes / pre-meeting prep"
    },
    "minutes_notes": {
      "type": "string",
      "description": "Meeting minutes \u2014 notes taken during or after the meeting"
    }
  },
  "required": [
    "title",
    "meeting_date"
  ]
}