{
  "name": "OnboardingTemplate",
  "type": "object",
  "properties": {
    "title": { "type": "string" },
    "description": { "type": "string" },
    "completion_type": {
      "type": "string",
      "enum": ["acknowledge", "e-sign", "fill-out-form", "watch-video"],
      "default": "acknowledge"
    },
    "file_url": { "type": "string", "description": "Document or video URL" },
    "is_required": { "type": "boolean", "default": true },
    "sort_order": { "type": "number", "default": 0 },
    "is_active": { "type": "boolean", "default": true }
  },
  "required": ["title", "completion_type"]
}