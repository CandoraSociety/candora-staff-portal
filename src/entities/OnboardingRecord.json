{
  "name": "OnboardingRecord",
  "type": "object",
  "properties": {
    "employee_id": { "type": "string" },
    "user_id": { "type": "string" },
    "template_id": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["pending", "completed", "skipped"],
      "default": "pending"
    },
    "completed_date": { "type": "string", "format": "date-time" },
    "signed_name": { "type": "string", "description": "Name typed for e-sign/NDA" },
    "notes": { "type": "string" }
  },
  "required": ["user_id", "template_id"]
}